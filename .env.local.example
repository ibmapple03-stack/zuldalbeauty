NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only — from Supabase Dashboard > Settings > API > service_role key.
# Never expose this to the browser or prefix it with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# From Paystack Dashboard > Settings > API Keys & Webhooks. The public key is
# safe to expose to the browser; the secret key is server-only and must
# never be prefixed with NEXT_PUBLIC_.
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_public_key
PAYSTACK_SECRET_KEY=sk_test_your_secret_key
